{
  "name": "intelcore-saas",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "web"
  ],
  "scripts": {
    "dev": "turbo dev",
    "dev:web": "pnpm --filter web dev",
    "dev:app": "pnpm --filter app start",
    "build": "turbo build",
    "build:web": "pnpm --filter web build",
    "build:app": "pnpm --filter app export",
    "deploy": "pnpm --filter web deploy"
  },
  "devDependencies": {
    "turbo": "^2.3.0"
  },
  "packageManager": "pnpm@9.0.0"
}